D_[EN|EN|EN|EN|EN|EN|EN|EN],[SS4END7|S4END7|S2MID7|S2END7|S2END3|S1END3|VCC0|GND0]

### # single just go back, we swap bits in vector to get more twists into the graph
N1BEG[0|1|2|3],S1END[3|2|1|0]
# Single get connected to PAD output
N1BEG[0|1|2|3],[A_OUT|B_OUT|C_OUT|D_OUT]

