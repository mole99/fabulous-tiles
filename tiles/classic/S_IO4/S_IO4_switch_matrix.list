D_[IN|IN|IN|IN|IN|IN|IN|IN],[SS4END3|S4END3|S2MID3|S2END7|S2END3|S1END3|VCC0|GND0]

# Tristate control for those PADs
A_[EN|EN|EN|EN|EN|EN|EN|EN],[SS4END4|S4END4|S2MID4|S2END4|S2END0|S1END0|VCC0|GND0]
