# N_IO4

# Global nets
A_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
B_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
C_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
D_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]

# Fabric to PAD output multiplexers
A_[IN|IN|IN|IN|IN|IN|IN|IN],[NN4END0|N4END0|N2MID0|N2END4|N2END0|N1END0|VCC0|GND0]
B_[IN|IN|IN|IN|IN|IN|IN|IN],[NN4END1|N4END1|N2MID1|N2END5|N2END1|N1END1|VCC0|GND0]
C_[IN|IN|IN|IN|IN|IN|IN|IN],[NN4END2|N4END2|N2MID2|N2END6|N2END2|N1END2|VCC0|GND0]
D_[IN|IN|IN|IN|IN|IN|IN|IN],[NN4END3|N4END3|N2MID3|N2END7|N2END3|N1END3|VCC0|GND0]

# Tristate control for those PADs
A_[EN|EN|EN|EN|EN|EN|EN|EN],[NN4END4|N4END4|N2MID4|N2END4|N2END0|N1END0|VCC0|GND0]
B_[EN|EN|EN|EN|EN|EN|EN|EN],[NN4END5|N4END5|N2MID5|N2END5|N2END1|N1END1|VCC0|GND0]
C_[EN|EN|EN|EN|EN|EN|EN|EN],[NN4END6|N4END6|N2MID6|N2END6|N2END2|N1END2|VCC0|GND0]
D_[EN|EN|EN|EN|EN|EN|EN|EN],[NN4END7|N4END7|N2MID7|N2END7|N2END3|N1END3|VCC0|GND0]

### # single just go back, we swap bits in vector to get more twists into the graph
S1BEG[0|1|2|3],N1END[3|2|1|0]
# Single get connected to PAD output
S1BEG[0|1|2|3],[A_OUT|B_OUT|C_OUT|D_OUT]

S4BEG[0|1|8|9],[A_OUT|B_OUT|C_OUT|D_OUT]
S4BEG[2|3|10|11],[A_OUT|B_OUT|C_OUT|D_OUT]
S4BEG[4|5|12|13],[A_OUT|B_OUT|C_OUT|D_OUT]
S4BEG[6|7|14|15],[A_OUT|B_OUT|C_OUT|D_OUT]

S4BEG[0|1|8|9],N1END[2|3|1|0]
S4BEG[2|3|10|11],NN4END[15|14|13|12]
S4BEG[4|5|12|13],N1END[2|3|1|0]
S4BEG[6|7|14|15],NN4END[15|14|13|12]

# The MID are half way in so they get connected to the longest patch (S2BEG)
# The END are longest so get on the cascading begin (S2BEGb)
# on top we twist wire indexes for more entropy
S2BEGb[0|1|2|3|4|5|6|7],N2END[7|6|5|4|3|2|1|0]
S2BEGb[0|1|2|3|4|5|6|7],NN4END[7|6|5|4|3|2|1|0]
S2BEGb[0|1|2|3|4|5|6|7],NN4END[15|14|13|12|11|10|9|8]
S2BEGb[0|1|2|3|4|5|6|7],N4END[7|6|5|4|3|2|1|0]

S2BEG[0|1|2|3|4|5|6|7],N2MID[7|6|5|4|3|2|1|0]
S2BEG[0|1|2|3|4|5|6|7],NN4END[7|6|5|4|3|2|1|0]
S2BEG[0|1|2|3|4|5|6|7],NN4END[15|14|13|12|11|10|9|8]
S2BEG[0|1|2|3|4|5|6|7],N4END[7|6|5|4|3|2|1|0]

SS4BEG[0|0|0|0],[A_OUT|N4END0|N4END2|N4END4]
SS4BEG[1|1|1|1],[B_OUT|N4END6|N4END8|N4END10]
SS4BEG[2|2|2|2],[C_OUT|N4END1|N4END3|N4END5]
SS4BEG[3|3|3|3],[D_OUT|N4END7|N4END9|N4END11]
SS4BEG[4|4|4|4],[N2END0|N2END2|N2END4|N2END6]
SS4BEG[5|5|5|5],[N2END1|N2END3|N2END5|N2END7]
SS4BEG[6|6|6|6],[N2MID0|N2MID2|N2MID4|N2MID6]
SS4BEG[7|7|7|7],[N2MID1|N2MID3|N2MID5|N2MID7]
SS4BEG[8|8|8|8],[N4END4|N4END6|N4END8|N4END10]
SS4BEG[9|9|9|9],[N4END1|N4END3|N4END5|N4END7]
SS4BEG1[0|0|0|0],[A_OUT|N4END0|N4END2|N4END4]
SS4BEG1[1|1|1|1],[B_OUT|N4END6|N4END8|N4END10]
SS4BEG1[2|2|2|2],[C_OUT|N4END1|N4END3|N4END5]
SS4BEG1[3|3|3|3],[D_OUT|N4END7|N4END9|N4END11]
SS4BEG1[4|4|4|4],[N2MID0|N2MID2|N2MID4|N2MID6]
SS4BEG1[5|5|5|5],[N2MID1|N2MID3|N2MID5|N2MID7]


