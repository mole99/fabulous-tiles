# SW_term

# IOBUF to any GBUF
GBUF_A_[IN|IN|IN|IN],S_GBUF_FEED_END[0|1|2|3]
GBUF_B_[IN|IN|IN|IN],S_GBUF_FEED_END[0|1|2|3]
GBUF_C_[IN|IN|IN|IN],S_GBUF_FEED_END[0|1|2|3]
GBUF_D_[IN|IN|IN|IN],S_GBUF_FEED_END[0|1|2|3]

GBUF_A_[IN],SYS_RESET_RESET
GBUF_B_[IN],SYS_RESET_RESET
GBUF_C_[IN],SYS_RESET_RESET
GBUF_D_[IN],SYS_RESET_RESET

# GBUF to north and east
