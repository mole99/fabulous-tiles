# E_term

# Global nets
N_GBUF_BEG[0|1|2|3],N_GBUF_END[0|1|2|3]

# single just go back, we swap bits in vector to get more twists into the graph
W1BEG[0|1|2|3|4|5|6|7],E1END[7|6|5|4|3|2|1|0]
W1BEG[0|1|2|3|4|5|6|7],E2END[7|6|5|4|3|2|1|0]
W1BEG[0|1|2|3|4|5|6|7],E2MID[7|6|5|4|3|2|1|0]
W1BEG[0|1|2|3|4|5|6|7],[E1END5|E1END3|E2END1|E2END6|E2MID0|E2MID7|VCC0|GND0]

# The MID are half way in so they get connected to the longest patch (S2BEG)
# The END are longest so get on the cascading begin (S2BEGb)
# on top we twist wire indexes for more entropy
W2BEGb[0|1|2|3|4|5|6|7],E1END[7|6|5|4|3|2|1|0]
W2BEGb[0|1|2|3|4|5|6|7],E2END[7|6|5|4|3|2|1|0]
W2BEGb[0|1|2|3|4|5|6|7],E2MID[7|6|5|4|3|2|1|0]
W2BEGb[0|1|2|3|4|5|6|7],[E1END5|E1END3|E2END1|E2END6|E2MID0|E2MID7|VCC0|GND0]

W2BEG[0|1|2|3|4|5|6|7],E1END[7|6|5|4|3|2|1|0]
W2BEG[0|1|2|3|4|5|6|7],E2END[7|6|5|4|3|2|1|0]
W2BEG[0|1|2|3|4|5|6|7],E2MID[7|6|5|4|3|2|1|0]
W2BEG[0|1|2|3|4|5|6|7],[E1END5|E1END3|E2END1|E2END6|E2MID0|E2MID7|VCC0|GND0]
