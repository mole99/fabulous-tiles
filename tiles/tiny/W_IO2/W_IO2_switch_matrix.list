# W_IO2

# These lines are used to feed the GBUFs in SW_term
S_GBUF_FEED_BEG[0|1|2|3],S_GBUF_FEED_END[0|1|2|3]
S_GBUF_FEED_BEG[0|1|2|3],[A_OUT|B_OUT|A_OUT|B_OUT]
S_GBUF_FEED_BEG[0|1|2|3],W1END[1|2|3|0]
S_GBUF_FEED_BEG[0|1|2|3],W2END[7|6|5|4]

# Global nets
A_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
B_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
N_GBUF_BEG[0|1|2|3],N_GBUF_END[0|1|2|3]

# Fabric to PAD output multiplexers
A_[IN|IN|IN|IN|IN|IN|IN|IN],W1END[7|6|5|4|3|2|1|0]
A_[IN|IN|IN|IN|IN|IN|IN|IN],[W2END7|W2END6|W2END5|W2MID2|W2MID1|W2MID0|VCC0|GND0]
B_[IN|IN|IN|IN|IN|IN|IN|IN],W1END[7|6|5|4|3|2|1|0]
B_[IN|IN|IN|IN|IN|IN|IN|IN],[W2END7|W2END6|W2END5|W2MID2|W2MID1|W2MID0|VCC0|GND0]

# Tristate control for those PADs
A_[EN|EN|EN|EN|EN|EN|EN|EN],[W2END0|W2END2|W2MID4|W2MID7|W1END7|W1END3|VCC0|GND0]
B_[EN|EN|EN|EN|EN|EN|EN|EN],[W2END0|W2END2|W2MID4|W2MID7|W1END7|W1END3|VCC0|GND0]

# single just go back, we swap bits in vector to get more twists into the graph
E1BEG[0|1|2|3|4|5|6|7],W1END[7|6|5|4|3|2|1|0]
E1BEG[0|1|2|3|4|5|6|7],W2END[7|6|5|4|3|2|1|0]
E1BEG[0|1|2|3|4|5|6|7],W2MID[7|6|5|4|3|2|1|0]
E1BEG[0|1|2|3|4|5|6|7],[A_OUT|B_OUT|A_OUT|B_OUT|A_OUT|B_OUT|A_OUT|B_OUT]

# The MID are half way in so they get connected to the longest patch (S2BEG)
# The END are longest so get on the cascading begin (S2BEGb)
# on top we twist wire indexes for more entropy
E2BEGb[0|1|2|3|4|5|6|7],W1END[7|6|5|4|3|2|1|0]
E2BEGb[0|1|2|3|4|5|6|7],W2END[7|6|5|4|3|2|1|0]
E2BEGb[0|1|2|3|4|5|6|7],W2MID[7|6|5|4|3|2|1|0]
E2BEGb[0|1|2|3|4|5|6|7],[B_OUT|A_OUT|B_OUT|A_OUT|B_OUT|A_OUT|B_OUT|A_OUT]

E2BEG[0|1|2|3|4|5|6|7],W1END[7|6|5|4|3|2|1|0]
E2BEG[0|1|2|3|4|5|6|7],W2END[7|6|5|4|3|2|1|0]
E2BEG[0|1|2|3|4|5|6|7],W2MID[7|6|5|4|3|2|1|0]
E2BEG[0|1|2|3|4|5|6|7],[A_OUT|B_OUT|A_OUT|B_OUT|A_OUT|B_OUT|A_OUT|B_OUT]
