# N_IO

# Global nets
A_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]

# Fabric to PAD output multiplexers
A_[IN|IN|IN|IN|IN|IN|IN|IN],N1END[7|6|5|4|3|2|1|0]
A_[IN|IN|IN|IN|IN|IN|IN|IN],N2END[7|6|5|4|3|2|1|0]

# Tristate control for those PADs
A_[EN|EN|EN|EN|EN|EN|EN|EN],[N2END0|N2END2|N2MID4|N2MID7|N1END7|N1END3|VCC0|GND0]

# single just go back, we swap bits in vector to get more twists into the graph
S1BEG[0|1|2|3|4|5|6|7],N1END[7|6|5|4|3|2|1|0]
S1BEG[0|1|2|3|4|5|6|7],N2END[7|6|5|4|3|2|1|0]
S1BEG[0|1|2|3|4|5|6|7],N2MID[7|6|5|4|3|2|1|0]
S1BEG[0|1|2|3|4|5|6|7],[A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT]

# The MID are half way in so they get connected to the longest patch (S2BEG)
# The END are longest so get on the cascading begin (S2BEGb)
# on top we twist wire indexes for more entropy
S2BEGb[0|1|2|3|4|5|6|7],N1END[7|6|5|4|3|2|1|0]
S2BEGb[0|1|2|3|4|5|6|7],N2END[7|6|5|4|3|2|1|0]
S2BEGb[0|1|2|3|4|5|6|7],N2MID[7|6|5|4|3|2|1|0]
S2BEGb[0|1|2|3|4|5|6|7],[A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT]

S2BEG[0|1|2|3|4|5|6|7],N1END[7|6|5|4|3|2|1|0]
S2BEG[0|1|2|3|4|5|6|7],N2END[7|6|5|4|3|2|1|0]
S2BEG[0|1|2|3|4|5|6|7],N2MID[7|6|5|4|3|2|1|0]
S2BEG[0|1|2|3|4|5|6|7],[A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT|A_OUT]
