# E_IO4

# Global nets
A_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
B_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
C_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
D_[CLK|CLK|CLK|CLK],N_GBUF_END[0|1|2|3]
N_GBUF_BEG[0|1|2|3],N_GBUF_END[0|1|2|3]

# Fabric to PAD output multiplexers
A_[IN|IN|IN|IN|IN|IN|IN|IN],E1END[7|6|5|4|3|2|1|0]
A_[IN|IN|IN|IN|IN|IN|IN|IN],[E2END7|E2END6|E2END5|E2MID2|E2MID1|E2MID0|VCC0|GND0]
B_[IN|IN|IN|IN|IN|IN|IN|IN],E1END[7|6|5|4|3|2|1|0]
B_[IN|IN|IN|IN|IN|IN|IN|IN],[E2END7|E2END6|E2END5|E2MID2|E2MID1|E2MID0|VCC0|GND0]
C_[IN|IN|IN|IN|IN|IN|IN|IN],E1END[7|6|5|4|3|2|1|0]
C_[IN|IN|IN|IN|IN|IN|IN|IN],[E2END7|E2END6|E2END5|E2MID2|E2MID1|E2MID0|VCC0|GND0]
D_[IN|IN|IN|IN|IN|IN|IN|IN],E1END[7|6|5|4|3|2|1|0]
D_[IN|IN|IN|IN|IN|IN|IN|IN],[E2END7|E2END6|E2END5|E2MID2|E2MID1|E2MID0|VCC0|GND0]

# Tristate control for those PADs
A_[EN|EN|EN|EN|EN|EN|EN|EN],[E2END0|E2END2|E2MID4|E2MID7|E1END7|E1END3|VCC0|GND0]
B_[EN|EN|EN|EN|EN|EN|EN|EN],[E2END0|E2END2|E2MID4|E2MID7|E1END7|E1END3|VCC0|GND0]
C_[EN|EN|EN|EN|EN|EN|EN|EN],[E2END0|E2END2|E2MID4|E2MID7|E1END7|E1END3|VCC0|GND0]
D_[EN|EN|EN|EN|EN|EN|EN|EN],[E2END0|E2END2|E2MID4|E2MID7|E1END7|E1END3|VCC0|GND0]

# single just go back, we swap bits in vector to get more twists into the graph
W1BEG[0|1|2|3|4|5|6|7],E1END[7|6|5|4|3|2|1|0]
W1BEG[0|1|2|3|4|5|6|7],E2END[7|6|5|4|3|2|1|0]
W1BEG[0|1|2|3|4|5|6|7],E2MID[7|6|5|4|3|2|1|0]
W1BEG[0|1|2|3|4|5|6|7],[A_OUT|B_OUT|C_OUT|D_OUT|A_OUT|B_OUT|C_OUT|D_OUT]

# The MID are half way in so they get connected to the longest patch (S2BEG)
# The END are longest so get on the cascading begin (S2BEGb)
# on top we twist wire indexes for more entropy
W2BEGb[0|1|2|3|4|5|6|7],E1END[7|6|5|4|3|2|1|0]
W2BEGb[0|1|2|3|4|5|6|7],E2END[7|6|5|4|3|2|1|0]
W2BEGb[0|1|2|3|4|5|6|7],E2MID[7|6|5|4|3|2|1|0]
W2BEGb[0|1|2|3|4|5|6|7],[D_OUT|C_OUT|C_OUT|A_OUT|D_OUT|C_OUT|B_OUT|A_OUT]

W2BEG[0|1|2|3|4|5|6|7],E1END[7|6|5|4|3|2|1|0]
W2BEG[0|1|2|3|4|5|6|7],E2END[7|6|5|4|3|2|1|0]
W2BEG[0|1|2|3|4|5|6|7],E2MID[7|6|5|4|3|2|1|0]
W2BEG[0|1|2|3|4|5|6|7],[A_OUT|B_OUT|C_OUT|D_OUT|A_OUT|B_OUT|C_OUT|D_OUT]
