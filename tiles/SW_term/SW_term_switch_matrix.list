# SW_term

# IOBUF to any GBUF
GBUF_BEG[0|1|2|3],[A_OUT|A_OUT|A_OUT|A_OUT]
GBUF_BEG[0|1|2|3],[B_OUT|B_OUT|B_OUT|B_OUT]
GBUF_BEG[0|1|2|3],[C_OUT|C_OUT|C_OUT|C_OUT]
GBUF_BEG[0|1|2|3],[D_OUT|D_OUT|D_OUT|D_OUT]

# CLK input of IOBUF
[A_CLK|A_CLK|A_CLK|A_CLK],GBUF_END[0|1|2|3|GND|VCC]
[B_CLK|B_CLK|B_CLK|B_CLK],GBUF_END[0|1|2|3|GND|VCC]
[C_CLK|C_CLK|C_CLK|C_CLK],GBUF_END[0|1|2|3|GND|VCC]
[D_CLK|D_CLK|D_CLK|D_CLK],GBUF_END[0|1|2|3|GND|VCC]

# GBUF to north and east
N_GBUF_BEG[0|1|2|3],GBUF_END[0|1|2|3]
E_GBUF_BEG[0|1|2|3],GBUF_END[0|1|2|3]
