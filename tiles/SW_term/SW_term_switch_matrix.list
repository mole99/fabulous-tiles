# SW_term

# IOBUF to any GBUF
GBUF_A_[IN|IN|IN|IN],[A_OUT|B_OUT|C_OUT|D_OUT]
GBUF_B_[IN|IN|IN|IN],[A_OUT|B_OUT|C_OUT|D_OUT]
GBUF_C_[IN|IN|IN|IN],[A_OUT|B_OUT|C_OUT|D_OUT]
GBUF_D_[IN|IN|IN|IN],[A_OUT|B_OUT|C_OUT|D_OUT]

# CLK input of IOBUF
[A_CLK|A_CLK|A_CLK|A_CLK|A_CLK|A_CLK],[GBUF_A_OUT|GBUF_B_OUT|GBUF_C_OUT|GBUF_D_OUT|GND0|VCC0]
[B_CLK|B_CLK|B_CLK|B_CLK|B_CLK|B_CLK],[GBUF_A_OUT|GBUF_B_OUT|GBUF_C_OUT|GBUF_D_OUT|GND0|VCC0]
[C_CLK|C_CLK|C_CLK|C_CLK|C_CLK|C_CLK],[GBUF_A_OUT|GBUF_B_OUT|GBUF_C_OUT|GBUF_D_OUT|GND0|VCC0]
[D_CLK|D_CLK|D_CLK|D_CLK|D_CLK|D_CLK],[GBUF_A_OUT|GBUF_B_OUT|GBUF_C_OUT|GBUF_D_OUT|GND0|VCC0]

# GBUF to north and east
N_GBUF_BEG[0|1|2|3],[GBUF_A_OUT|GBUF_B_OUT|GBUF_C_OUT|GBUF_D_OUT]
E_GBUF_BEG[0|1|2|3],[GBUF_A_OUT|GBUF_B_OUT|GBUF_C_OUT|GBUF_D_OUT]
